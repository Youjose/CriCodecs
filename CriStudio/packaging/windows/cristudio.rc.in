#include <winver.h>

#define IDI_CRISTUDIO 101

IDI_CRISTUDIO ICON "@CRISTUDIO_WINDOWS_ICON@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @CRISTUDIO_VERSION_MAJOR@,@CRISTUDIO_VERSION_MINOR@,@CRISTUDIO_VERSION_PATCH@,0
 PRODUCTVERSION @CRISTUDIO_VERSION_MAJOR@,@CRISTUDIO_VERSION_MINOR@,@CRISTUDIO_VERSION_PATCH@,0
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "CriCodecs\0"
            VALUE "FileDescription", "CriStudio\0"
            VALUE "FileVersion", "@CRISTUDIO_VERSION@\0"
            VALUE "InternalName", "CriStudio\0"
            VALUE "OriginalFilename", "CriStudio.exe\0"
            VALUE "ProductName", "CriStudio\0"
            VALUE "ProductVersion", "@CRISTUDIO_VERSION@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
